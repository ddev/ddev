{
  "permissions": {
    "allow": [
      "Bash(curl*github.com*)",
      "Bash(curl*raw.githubusercontent.com*)",
      "Bash(curl*buildkite.com*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue status*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr status*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(make*)",
      "Bash(go test*)",
      "Bash(gofmt*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(sed*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(cut*)",
      "Bash(tr*)",
      "Bash(diff*)",
      "Bash(find*)",
      "Bash(which*)",
      "Bash(type*)",
      "Bash(echo*)",
      "Bash(printf*)",
      "Bash(jq*)",
      "Bash(awk*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(golangci-lint*)",
      "Bash(markdownlint*)",
      "WebFetch(domain:*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(sed*-i*)",
      "Bash(find*-delete*)",
      "Bash(find*-exec rm*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "make staticrequired"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *.go) gofmt -w \"$f\" 2>/dev/null ;; esac; done"
          },
          {
            "type": "command",
            "command": "for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *.md) markdownlint --fix \"$f\" 2>/dev/null || true ;; esac; done"
          }
        ]
      }
    ]
  }
}
